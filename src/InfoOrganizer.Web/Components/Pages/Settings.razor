@page "/settings"
@rendermode InteractiveServer
@using System.Globalization
@inject CatalogService Catalog
@inject ILocalSettingsService LocalSettings
@inject InfoOrganizer.Ai.IAiClient Ai
@inject NavigationManager Nav
@inject IStringLocalizer<AppStrings> L

<PageTitle>@L["Settings_Title"]</PageTitle>

<h1>@L["Settings_Title"]</h1>

<h2 class="h5 mt-3">@L["Settings_AiFeatures"]</h2>
@if (Ai.IsConfigured)
{
    <p class="text-success mb-2">@L["Settings_AiConfigured"]</p>
}
else
{
    <p class="text-muted mb-2">@L["Settings_AiNotConfigured"]</p>
}

@if (_savedKeyHint is not null)
{
    <p class="small text-muted mb-2">@L["Settings_SavedKey"] <code>@_savedKeyHint</code></p>
}

<div class="d-flex flex-column flex-sm-row gap-2 align-items-sm-end mb-2" style="max-width: 640px">
    <div class="flex-grow-1">
        <label class="form-label" for="anthropic-api-key">@L["Settings_AnthropicApiKey"]</label>
        <input id="anthropic-api-key" type="password" class="form-control" autocomplete="off"
               placeholder="@(_hasSavedAnthropicApiKey ? L["Settings_PlaceholderReplaceKey"] : L["Settings_PlaceholderPasteKey"])"
               @bind="_anthropicApiKeyInput" />
    </div>
    <button class="btn btn-primary" @onclick="SaveAnthropicKey">@L["Common_Save"]</button>
    @if (_hasSavedAnthropicApiKey)
    {
        <button class="btn btn-outline-danger" @onclick="RemoveAnthropicKey">@L["Settings_RemoveKey"]</button>
    }
</div>

@if (_aiSettingsMessage is not null)
{
    <p class="small text-success">@_aiSettingsMessage</p>
}

<h2 class="h5 mt-4">@L["Settings_Language"]</h2>
<div class="btn-group btn-group-sm mb-2" role="group">
    <a class="btn @LanguageButtonClass("es")" href="@CultureLink("es-MX")">@L["Settings_LanguageSpanish"]</a>
    <a class="btn @LanguageButtonClass("en")" href="@CultureLink("en-US")">@L["Settings_LanguageEnglish"]</a>
</div>

<h2 class="h5 mt-4">@L["Settings_ReorderThresholds"]</h2>
<p class="text-muted">@L["Settings_ReorderIntro"]</p>

@if (_products is null)
{
    <p>@L["Common_Loading"]</p>
}
else if (_products.Count == 0)
{
    <p class="text-muted">@L["Settings_NoProductsFirst"] <a href="upload">@L["Settings_ImportSomeRecordsFirst"]</a> @L["Settings_First"]</p>
}
else
{
    <table class="table table-sm align-middle" style="max-width: 640px">
        <thead><tr><th>@L["Common_Product"]</th><th>@L["Common_Code"]</th><th style="width: 9rem">@L["Inventory_ReorderAt"]</th><th></th></tr></thead>
        <tbody>
            @foreach (var p in _products)
            {
                <tr>
                    <td>@p.Name</td>
                    <td>@p.Sku</td>
                    <td><input type="number" class="form-control form-control-sm" @bind="_thresholds[p.Id]" /></td>
                    <td>
                        <button class="btn btn-sm btn-outline-primary" @onclick="() => SaveThresholdAsync(p.Id)">@L["Common_Save"]</button>
                        @if (_savedId == p.Id)
                        {
                            <span class="text-success small ms-1">@L["Common_Saved"]</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<h2 class="h5 mt-4">@L["Settings_SavedMappings"]</h2>
<p class="text-muted">@L["Settings_SavedMappingsIntro"]</p>

@if (_profiles is null)
{
    <p>@L["Common_Loading"]</p>
}
else if (_profiles.Count == 0)
{
    <p class="text-muted">@L["Settings_NoSavedMappings"]</p>
}
else
{
    <ul class="list-group" style="max-width: 640px">
        @foreach (var pr in _profiles)
        {
            <li class="list-group-item d-flex justify-content-between align-items-center">
                <span>@pr.Name <span class="badge text-bg-light">@pr.DefaultRecordType.Display(L)</span></span>
                <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteProfileAsync(pr.Id)">@L["Common_Delete"]</button>
            </li>
        }
    </ul>
}

@code {
    private IReadOnlyList<Product>? _products;
    private IReadOnlyList<ProfileInfo>? _profiles;
    private Dictionary<int, decimal?> _thresholds = new();
    private int? _savedId;
    private string? _anthropicApiKeyInput;
    private string? _savedKeyHint;
    private bool _hasSavedAnthropicApiKey;
    private string? _aiSettingsMessage;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        LoadAiSettings();
        _products = await Catalog.GetProductsAsync();
        _thresholds = _products.ToDictionary(p => p.Id, p => p.ReorderThreshold);
        _profiles = await Catalog.GetProfilesAsync();
    }

    private void LoadAiSettings()
    {
        _hasSavedAnthropicApiKey = LocalSettings.HasSavedAnthropicApiKey();
        _savedKeyHint = _hasSavedAnthropicApiKey ? MaskKey(LocalSettings.GetAnthropicApiKey()) : null;
    }

    private void SaveAnthropicKey()
    {
        if (string.IsNullOrWhiteSpace(_anthropicApiKeyInput))
            return;

        LocalSettings.SaveAnthropicApiKey(_anthropicApiKeyInput);
        _anthropicApiKeyInput = null;
        _aiSettingsMessage = L["Settings_MsgSaved"];
        LoadAiSettings();
    }

    private void RemoveAnthropicKey()
    {
        LocalSettings.RemoveAnthropicApiKey();
        _anthropicApiKeyInput = null;
        _aiSettingsMessage = L["Settings_MsgRemoved"];
        LoadAiSettings();
    }

    private string CultureLink(string culture) =>
        $"/culture/set?culture={Uri.EscapeDataString(culture)}&redirectUri={Uri.EscapeDataString(CurrentLocalPath())}";

    private string CurrentLocalPath()
    {
        var relative = "/" + Nav.ToBaseRelativePath(Nav.Uri);
        return relative.StartsWith("//") ? "/settings" : relative;
    }

    private static string LanguageButtonClass(string language) =>
        CultureInfo.CurrentUICulture.TwoLetterISOLanguageName.Equals(language, StringComparison.OrdinalIgnoreCase)
            ? "btn-primary"
            : "btn-outline-secondary";

    private async Task SaveThresholdAsync(int id)
    {
        await Catalog.SetReorderThresholdAsync(id, _thresholds[id]);
        _savedId = id;
    }

    private async Task DeleteProfileAsync(int id)
    {
        await Catalog.DeleteProfileAsync(id);
        _profiles = await Catalog.GetProfilesAsync();
    }

    private static string? MaskKey(string? key)
    {
        if (string.IsNullOrWhiteSpace(key))
            return null;

        var trimmed = key.Trim();
        var suffix = trimmed.Length <= 4 ? trimmed : trimmed[^4..];
        return trimmed.StartsWith("sk-ant-", StringComparison.OrdinalIgnoreCase)
            ? $"sk-ant-...{suffix}"
            : $"...{suffix}";
    }
}
