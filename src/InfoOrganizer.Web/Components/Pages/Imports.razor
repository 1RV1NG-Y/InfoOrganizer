@page "/imports"
@rendermode InteractiveServer
@inject ImportService Importer
@inject IStringLocalizer<AppStrings> L

<PageTitle>@L["Imports_Title"]</PageTitle>

<h1>@L["Imports_Title"]</h1>

@if (_batches is null)
{
    <p>@L["Common_Loading"]</p>
}
else if (_batches.Count == 0)
{
    <p class="text-muted">@L["Imports_NoImports"] <a href="upload">@L["Imports_UploadToStart"]</a> @L["Imports_ToGetStarted"]</p>
}
else
{
    <div class="table-responsive">
        <table class="table table-sm table-striped align-middle">
            <thead>
                <tr>
                    <th>@L["Common_File"]</th>
                    <th>@L["Common_Type"]</th>
                    <th>@L["Common_Status"]</th>
                    <th class="text-end">@L["Imports_ColRows"]</th>
                    <th class="text-end">@L["ReviewRows_Ready"]</th>
                    <th class="text-end">@L["ReviewRows_NeedsReview"]</th>
                    <th class="text-end">@L["ReviewRows_Applied"]</th>
                    <th class="text-end">@L["ReviewRows_Rejected"]</th>
                    <th>@L["Imports_ColImported"]</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var batch in _batches)
                {
                    <tr>
                        <td><a href="@($"/imports/{batch.BatchId}")">@batch.FileName</a></td>
                        <td>@batch.SourceType.Display(L)</td>
                        <td><span class="badge @StatusClass(batch.Status)">@batch.Status.Display(L)</span></td>
                        <td class="text-end">@batch.RowCount</td>
                        <td class="text-end">@batch.ReadyRows</td>
                        <td class="text-end">@batch.NeedsReviewRows</td>
                        <td class="text-end">@batch.AppliedRows</td>
                        <td class="text-end">@batch.RejectedRows</td>
                        <td>@batch.ImportedAtUtc.ToLocalTime().ToString("g")</td>
                        <td><a class="btn btn-sm btn-outline-primary" href="@($"/imports/{batch.BatchId}/review")">@L["Common_Open"]</a></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private IReadOnlyList<ImportBatchListItem>? _batches;

    protected override async Task OnInitializedAsync()
        => _batches = await Importer.GetImportBatchesAsync();

    private static string StatusClass(ImportStatus status) => status switch
    {
        ImportStatus.Imported => "text-bg-success",
        ImportStatus.AwaitingReview => "text-bg-warning",
        ImportStatus.Failed => "text-bg-danger",
        _ => "text-bg-secondary"
    };
}
