@page "/review"
@rendermode InteractiveServer
@inject ImportService Importer
@inject ImportSession Session
@inject NavigationManager Nav
@inject IStringLocalizer<AppStrings> L

<PageTitle>@L["Review_Title"]</PageTitle>

@if (!Session.HasWork)
{
    <h1>@L["Review_Title"]</h1>
    <p class="text-muted">@L["Review_NothingToReview"] <a href="upload">@L["Review_UploadFileFirst"]</a></p>
}
else
{
    var preview = Session.Previews[_index];
    var table = preview.Table;

    <h1>@L["Review_Title"]</h1>

    @if (Session.Previews.Count > 1)
    {
        <div class="mb-3">
            <label class="form-label">@L["Review_SheetOrTable"]</label>
            <select class="form-select w-auto" @bind="_index" @bind:after="EnsureFields">
                @for (var i = 0; i < Session.Previews.Count; i++)
                {
                    var p = Session.Previews[i];
                    <option value="@i">@(p.Table.Meta.SheetName ?? p.FileName) (@L["Review_RowsSuffix", p.Table.Rows.Count])</option>
                }
            </select>
        </div>
    }

    @if (!preview.Resolution.RequiresConfirmation)
    {
        <div class="alert alert-info">@L["Review_RecognizedFormat"]</div>
    }
    else
    {
        <div class="alert alert-secondary">
            @(string.IsNullOrEmpty(Proposal.Rationale)
                ? L["Review_ProposedBy", preview.Resolution.Source].Value
                : L["Review_ProposedByWithRationale", preview.Resolution.Source, Proposal.Rationale].Value)
        </div>
    }

    <div class="row">
        <div class="col-lg-6">
            <h2 class="h5">@L["Review_ColumnMapping"]</h2>
            <table class="table table-sm align-middle">
                <thead><tr><th>@L["Review_Field"]</th><th>@L["Review_SourceColumn"]</th><th>@L["Common_Confidence"]</th></tr></thead>
                <tbody>
                    @foreach (var info in CanonicalSchema.Fields)
                    {
                        var fm = Field(info.Field);
                        <tr>
                            <td>
                                @info.Field.Display(L)
                                @if (info.Required)
                                {
                                    <span class="text-danger">*</span>
                                }
                            </td>
                            <td>
                                <select class="form-select form-select-sm"
                                        value="@(fm.SourceColumn ?? "")"
                                        @onchange="e => SetColumn(info.Field, e.Value?.ToString())">
                                    <option value="">@L["Review_ColumnNone"]</option>
                                    @foreach (var c in table.Columns)
                                    {
                                        <option value="@c.Name">@c.Name</option>
                                    }
                                </select>
                            </td>
                            <td>
                                @if (fm.SourceColumn is not null && fm.Confidence > 0)
                                {
                                    <span class="badge text-bg-light">@($"{fm.Confidence:P0}")</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="col-lg-6">
            <h2 class="h5">@L["Review_SourcePreview"]</h2>
            <div class="table-responsive" style="max-height: 320px; overflow:auto;">
                <table class="table table-sm table-bordered small">
                    <thead><tr>@foreach (var c in table.Columns) { <th>@c.Name</th> }</tr></thead>
                    <tbody>
                        @foreach (var row in table.Rows.Take(8))
                        {
                            <tr>@foreach (var c in table.Columns) { <td>@row[c.Name]</td> }</tr>
                        }
                    </tbody>
                </table>
            </div>
            @if (table.Rows.Count > 8)
            {
                <p class="text-muted small">@L["Review_MoreRows", table.Rows.Count - 8]</p>
            }
        </div>
    </div>

    <hr />
    <div class="row g-3 align-items-end">
        <div class="col-auto">
            <label class="form-label">@L["Review_TheseRecordsAre"]</label>
            <select class="form-select form-select-sm" @bind="Proposal.DetectedRecordType">
                @foreach (var rt in Enum.GetValues<RecordType>())
                {
                    <option value="@rt">@rt.Display(L)</option>
                }
            </select>
        </div>
        <div class="col-auto">
            <label class="form-label">@L["Review_DateFormat"]</label>
            <input class="form-control form-control-sm" placeholder="@L["Review_DateFormatAuto"]" @bind="Proposal.Hints.DateFormat" />
        </div>
        <div class="col-auto">
            <label class="form-label">@L["Common_Currency"]</label>
            <input class="form-control form-control-sm" style="width:6rem" @bind="Proposal.Hints.DefaultCurrency" />
        </div>
        <div class="col-auto">
            <div class="form-check">
                <input class="form-check-input" type="checkbox" id="comma" @bind="Proposal.Hints.DecimalComma" />
                <label class="form-check-label" for="comma">@L["Review_CommaDecimals"]</label>
            </div>
        </div>
    </div>

    <div class="row g-3 align-items-end mt-1">
        <div class="col-auto">
            <div class="form-check">
                <input class="form-check-input" type="checkbox" id="save" @bind="_saveProfile" />
                <label class="form-check-label" for="save">@L["Review_RememberMapping"]</label>
            </div>
        </div>
        @if (_saveProfile)
        {
            <div class="col-auto">
                <input class="form-control form-control-sm" placeholder="@L["Review_MappingName"]" @bind="_profileName" />
            </div>
        }
    </div>

    @if (_error is not null)
    {
        <div class="alert alert-danger mt-3">@_error</div>
    }

    <div class="mt-3">
        <button class="btn btn-primary" disabled="@(!CanStage || _staging)" @onclick="StageAsync">
            @if (_staging)
            {
                <span class="spinner-border spinner-border-sm me-1"></span>
            }
            @L["Review_StageRows", table.Rows.Count]
        </button>
        <a class="btn btn-outline-secondary" href="upload">@L["Common_Cancel"]</a>
        @if (!CanStage)
        {
            <span class="text-danger ms-2 small">@L["Review_MapAtLeast"]</span>
        }
    </div>
}

@code {
    private int _index;
    private bool _saveProfile = true;
    private string _profileName = "";
    private bool _staging;
    private string? _error;

    private MappingProposal Proposal => Session.Previews[_index].Resolution.Proposal;

    protected override void OnInitialized()
    {
        if (Session.HasWork)
        {
            _profileName = Session.Previews[0].FileName;
            EnsureFields();
        }
    }

    private void EnsureFields()
    {
        foreach (var info in CanonicalSchema.Fields)
            if (Proposal.Fields.All(f => f.Field != info.Field))
                Proposal.Fields.Add(new FieldMapping { Field = info.Field, SourceColumn = null, Confidence = 0 });
    }

    private FieldMapping Field(CanonicalField field) => Proposal.Fields.First(f => f.Field == field);

    private void SetColumn(CanonicalField field, string? value)
        => Field(field).SourceColumn = string.IsNullOrEmpty(value) ? null : value;

    private bool CanStage =>
        (Field(CanonicalField.ProductName).SourceColumn is not null
        || Field(CanonicalField.Sku).SourceColumn is not null)
        && Field(CanonicalField.Quantity).SourceColumn is not null;

    private async Task StageAsync()
    {
        _staging = true;
        _error = null;
        try
        {
            var preview = Session.Previews[_index];
            var staged = await Importer.StageAsync(preview, Proposal, _profileName, _saveProfile);
            Session.Clear();
            Nav.NavigateTo($"/imports/{staged.BatchId}/review");
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _staging = false;
        }
    }
}
