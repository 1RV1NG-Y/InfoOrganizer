@page "/imports/{BatchId:int}"
@rendermode InteractiveServer
@using System.Text.Json
@inject ImportService Importer
@inject IStringLocalizer<AppStrings> L

<PageTitle>@L["ImportDetail_Title"]</PageTitle>

@if (_details is null)
{
    <h1>@L["ImportDetail_Title"]</h1>
    @if (_missing)
    {
        <p class="text-muted">@L["ReviewRows_BatchNotFound"]</p>
    }
    else
    {
        <p>@L["Common_Loading"]</p>
    }
}
else
{
    <div class="d-flex flex-wrap justify-content-between align-items-start gap-2 mb-3">
        <div>
            <h1 class="mb-1">@_details.FileName</h1>
            <div class="d-flex flex-wrap align-items-center gap-2 text-muted">
                <span class="badge text-bg-light border">@_details.SourceType.Display(L)</span>
                <span class="badge @BatchStatusClass(_details.Status)">@_details.Status.Display(L)</span>
                <span>@_details.ImportedAtUtc.ToLocalTime().ToString("g")</span>
            </div>
        </div>
        <a class="btn btn-primary" href="@($"/imports/{BatchId}/review")">@L["ImportDetail_OpenReview"]</a>
    </div>

    <div class="row g-2 mb-4">
        <div class="col-sm-6 col-lg-2">
            <div class="border rounded p-2 h-100">
                <div class="text-muted small">@L["ImportDetail_TotalRows"]</div>
                <div class="fs-5">@_details.RowCount</div>
            </div>
        </div>
        <div class="col-sm-6 col-lg-2">
            <div class="border rounded p-2 h-100">
                <div class="text-muted small">@L["ReviewRows_Ready"]</div>
                <div class="fs-5">@_details.ReadyRows</div>
            </div>
        </div>
        <div class="col-sm-6 col-lg-2">
            <div class="border rounded p-2 h-100">
                <div class="text-muted small">@L["ReviewRows_NeedsReview"]</div>
                <div class="fs-5">@_details.NeedsReviewRows</div>
            </div>
        </div>
        <div class="col-sm-6 col-lg-2">
            <div class="border rounded p-2 h-100">
                <div class="text-muted small">@L["ReviewRows_Applied"]</div>
                <div class="fs-5">@_details.AppliedRows</div>
            </div>
        </div>
        <div class="col-sm-6 col-lg-2">
            <div class="border rounded p-2 h-100">
                <div class="text-muted small">@L["ReviewRows_Rejected"]</div>
                <div class="fs-5">@_details.RejectedRows</div>
            </div>
        </div>
        <div class="col-sm-6 col-lg-2">
            <div class="border rounded p-2 h-100">
                <div class="text-muted small">@L["ImportDetail_SourceProfile"]</div>
                @if (string.IsNullOrWhiteSpace(_details.SourceProfileName))
                {
                    <div>@L["Common_None"]</div>
                }
                else
                {
                    <div>@_details.SourceProfileName</div>
                    <code class="small">@TruncateFingerprint(_details.SourceProfileFingerprint)</code>
                }
            </div>
        </div>
    </div>

    <section class="mb-4">
        <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-2">
            <h2 class="h5 mb-0">@L["ImportDetail_ReviewRows"]</h2>
            <a class="btn btn-sm btn-outline-primary" href="@($"/imports/{BatchId}/review")">@L["ImportDetail_ReviewRows"]</a>
        </div>
        <div class="table-responsive">
            <table class="table table-sm table-striped align-middle">
                <thead>
                    <tr>
                        <th>@L["Common_Row"]</th>
                        <th>@L["Common_Status"]</th>
                        <th>@L["Common_Confidence"]</th>
                        <th>@L["Common_Product"]</th>
                        <th class="text-end">@L["Common_QuantityShort"]</th>
                        <th>@L["Common_Kind"]</th>
                        <th>@L["Common_Location"]</th>
                        <th>@L["Common_Issues"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var detail in _details.ReviewRows)
                    {
                        var row = detail.Row;
                        <tr>
                            <td>@(row.RowIndex + 1)</td>
                            <td><span class="badge @ReviewStatusClass(row.Status)">@row.Status.Display(L)</span></td>
                            <td>@($"{row.Confidence:P0}")</td>
                            <td>@(row.ProductName ?? row.Sku)</td>
                            <td class="text-end">@row.Quantity</td>
                            <td>@row.Kind.Display(L)</td>
                            <td>@row.LocationName</td>
                            <td>
                                @foreach (var issue in Issues(row))
                                {
                                    <div class="small text-danger">@issue</div>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>

    <section class="mb-4">
        <h2 class="h5">@L["ImportDetail_RawSourceRows"]</h2>
        @if (_details.RawRecords.Count == 0)
        {
            <p class="text-muted">@L["ImportDetail_NoRawRows"]</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-sm table-striped align-middle">
                    <thead>
                        <tr>
                            <th>@L["Common_Row"]</th>
                            @foreach (var column in _rawColumns)
                            {
                                <th>@column</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var raw in _details.RawRecords)
                        {
                            <tr>
                                <td>@(raw.RowIndex + 1)</td>
                                @foreach (var column in _rawColumns)
                                {
                                    <td>@RawCell(raw.Id, column)</td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>

    <section class="mb-4">
        <h2 class="h5">@L["ImportDetail_CreatedMovements"]</h2>
        @if (_details.Movements.Count == 0)
        {
            <p class="text-muted">@L["ImportDetail_NoMovements"]</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-sm table-striped align-middle">
                    <thead>
                        <tr>
                            <th>@L["Common_Product"]</th>
                            <th>@L["Common_Kind"]</th>
                            <th class="text-end">@L["Common_QuantityShort"]</th>
                            <th class="text-end">@L["Common_UnitPrice"]</th>
                            <th>@L["Common_CurrencyShort"]</th>
                            <th>@L["Common_Date"]</th>
                            <th>@L["Common_Location"]</th>
                            <th>@L["ImportDetail_SourceRow"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var movement in _details.Movements)
                        {
                            <tr>
                                <td>@movement.ProductName</td>
                                <td><span class="badge @KindClass(movement.Kind)">@movement.Kind.Display(L)</span></td>
                                <td class="text-end">@movement.Quantity</td>
                                <td class="text-end">@movement.UnitPrice</td>
                                <td>@movement.Currency</td>
                                <td>@movement.OccurredOn</td>
                                <td>@movement.LocationName</td>
                                <td>@SourceRow(movement.SourceRowIndex)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>
}

@code {
    [Parameter] public int BatchId { get; set; }

    private ImportBatchDetails? _details;
    private bool _missing;
    private readonly Dictionary<int, IReadOnlyDictionary<string, string?>> _rawCellsById = new();
    private IReadOnlyList<string> _rawColumns = Array.Empty<string>();

    protected override async Task OnParametersSetAsync()
    {
        _details = await Importer.GetImportBatchDetailsAsync(BatchId);
        _missing = _details is null;
        BuildRawCellIndex();
    }

    private void BuildRawCellIndex()
    {
        _rawCellsById.Clear();
        _rawColumns = Array.Empty<string>();
        if (_details is null) return;

        var columns = new List<string>();
        var seen = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
        foreach (var raw in _details.RawRecords)
        {
            var cells = ParseCells(raw.DataJson);
            _rawCellsById[raw.Id] = cells;
            foreach (var key in cells.Keys)
            {
                if (seen.Add(key))
                    columns.Add(key);
            }
        }

        _rawColumns = columns;
    }

    private string? RawCell(int rawRecordId, string column) =>
        _rawCellsById.TryGetValue(rawRecordId, out var cells) && cells.TryGetValue(column, out var value)
            ? value
            : null;

    private static IReadOnlyDictionary<string, string?> ParseCells(string rawJson)
    {
        if (string.IsNullOrWhiteSpace(rawJson))
            return new Dictionary<string, string?>();

        try
        {
            using var doc = JsonDocument.Parse(rawJson);
            if (doc.RootElement.ValueKind != JsonValueKind.Object)
                return new Dictionary<string, string?>();

            var cells = new Dictionary<string, string?>();
            foreach (var property in doc.RootElement.EnumerateObject())
            {
                cells[property.Name] = property.Value.ValueKind switch
                {
                    JsonValueKind.Null => null,
                    JsonValueKind.String => property.Value.GetString(),
                    _ => property.Value.ToString()
                };
            }

            return cells;
        }
        catch (JsonException)
        {
            return new Dictionary<string, string?>();
        }
    }

    private static IReadOnlyList<string> Issues(ReviewRow row)
    {
        if (string.IsNullOrWhiteSpace(row.IssuesJson))
            return Array.Empty<string>();

        return JsonSerializer.Deserialize<List<string>>(row.IssuesJson) ?? new List<string>();
    }

    private static string BatchStatusClass(ImportStatus status) => status switch
    {
        ImportStatus.Imported => "text-bg-success",
        ImportStatus.AwaitingReview => "text-bg-warning",
        ImportStatus.Failed => "text-bg-danger",
        _ => "text-bg-secondary"
    };

    private static string ReviewStatusClass(ReviewRowStatus status) => status switch
    {
        ReviewRowStatus.Ready => "text-bg-success",
        ReviewRowStatus.Applied => "text-bg-primary",
        ReviewRowStatus.Rejected => "text-bg-secondary",
        _ => "text-bg-warning"
    };

    private static string KindClass(MovementKind kind) => kind switch
    {
        MovementKind.In => "text-bg-success",
        MovementKind.Out => "text-bg-danger",
        _ => "text-bg-secondary"
    };

    private static string TruncateFingerprint(string? fingerprint)
    {
        if (string.IsNullOrWhiteSpace(fingerprint))
            return "";

        return fingerprint.Length <= 12 ? fingerprint : fingerprint[..12];
    }

    private static string SourceRow(int? rowIndex) => rowIndex is { } index ? (index + 1).ToString() : "";
}
